---
import '../components/framer/styles.css';
import FramerNav from '../components/FramerNav.tsx';
import FramerFooter from '../components/FramerFooter.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';

interface Props {
  title?: string;
}

const { title = 'Colton Carroll' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <FramerNav client:only="react" />
    <ThemeToggle client:load />
    <slot />
    <FramerFooter client:only="react" />
  </body>
</html>
