---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { identity } from '../data/site';

interface Props {
  title?: string;
}

const { title = `${identity.name} | Software Engineer` } = Astro.props;
const updated = new Date().toISOString().slice(0, 7); // build date, YYYY-MM
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={identity.blurb} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add('js');
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || (!stored && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <div class="wrap">
      <nav>
        <a href="/" class="brand">colton.carroll</a>
        <ul>
          <li><a href={identity.resume} target="_blank">resume</a></li>
          <li><a href={identity.github} target="_blank" rel="noopener">github</a></li>
          <li><a href={identity.linkedin} target="_blank" rel="noopener">linkedin</a></li>
          <li><button id="theme-btn" aria-label="Toggle dark mode">◐</button></li>
        </ul>
      </nav>
      <slot />
      <footer>
        <span>{identity.location} · <a href={`mailto:${identity.email}`}>{identity.email}</a></span>
        <span>last updated {updated}</span>
      </footer>
    </div>
    <script is:inline>
      document.getElementById('theme-btn').addEventListener('click', () => {
        const dark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      });

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
