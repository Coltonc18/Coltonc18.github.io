---
import Layout from '../layouts/Layout.astro';
import FramerExperienceTitle from '../components/FramerExperienceTitle.tsx';
---

<Layout title="About | Colton Carroll">
  <main class="about-page">

    <!-- Hero / Bio Section -->
    <section class="about-hero">
      <div class="container">
        <h1 class="about-heading">About Me</h1>
        <p class="about-bio">
          I'm Colton Carroll, a software engineer who builds clean, performant web
          applications. I focus on the full stack — from thoughtful API design and
          data modeling on the backend to fast, accessible interfaces on the front.
          I enjoy working on products that solve real problems and care deeply about
          code quality, developer experience, and shipping things that actually work.
        </p>
        <p class="about-bio">
          When I'm not writing code I'm usually reading, hiking, or experimenting
          with side projects that scratch whatever technical itch I have that week.
        </p>
      </div>
    </section>

    <!-- Skills Section (no progress bars by design) -->
    <section class="about-skills">
      <div class="container">
        <h2 class="section-heading">Skills</h2>

        <div class="skills-group">
          <h3 class="skills-group-heading">Languages</h3>
          <ul class="skills-list">
            <li>TypeScript / JavaScript</li>
            <li>Python</li>
            <li>SQL</li>
            <li>HTML / CSS</li>
          </ul>
        </div>

        <div class="skills-group">
          <h3 class="skills-group-heading">Frameworks &amp; Libraries</h3>
          <ul class="skills-list">
            <li>React</li>
            <li>Astro</li>
            <li>Node.js</li>
            <li>FastAPI / Flask</li>
            <li>Tailwind CSS</li>
          </ul>
        </div>

        <div class="skills-group">
          <h3 class="skills-group-heading">Tools &amp; Platforms</h3>
          <ul class="skills-list">
            <li>Git / GitHub</li>
            <li>Docker</li>
            <li>PostgreSQL</li>
            <li>GitHub Actions (CI/CD)</li>
          </ul>
        </div>

        <!-- Experience Title Component for section header (Framer CDN) -->
        <FramerExperienceTitle client:only="react" title="Experience" subtitle="Where I've worked and what I've built" />
      </div>
    </section>

    <!-- Experience Section -->
    <section class="about-experience">
      <div class="container">
        <div class="experience-entry">
          <div class="experience-meta">
            <span class="experience-company">Software Engineer</span>
            <span class="experience-period">2022 — Present</span>
          </div>
          <p class="experience-desc">
            Full-stack development across web applications. Responsible for API design,
            database modeling, frontend implementation, and deployment pipelines.
          </p>
        </div>

        <div class="experience-entry">
          <div class="experience-meta">
            <span class="experience-company">Junior Developer</span>
            <span class="experience-period">2020 — 2022</span>
          </div>
          <p class="experience-desc">
            Built and maintained internal tooling and customer-facing features,
            working primarily with Python backends and React frontends.
          </p>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .about-page {
    background-color: var(--framer-color-bg-primary);
    color: var(--framer-color-text-primary);
    min-height: 100vh;
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .about-hero {
    padding: 6rem 0 3rem;
  }

  .about-heading {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    color: var(--framer-color-text-primary);
  }

  .about-bio {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--framer-color-text-secondary);
    margin: 0 0 1.25rem;
  }

  /* Skills */
  .about-skills {
    padding: 3rem 0;
    border-top: 1px solid var(--framer-color-border);
  }

  .section-heading {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 2rem;
    color: var(--framer-color-text-primary);
  }

  .skills-group {
    margin-bottom: 2rem;
  }

  .skills-group-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--framer-color-text-tertiary);
    margin: 0 0 0.75rem;
  }

  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skills-list li {
    background-color: var(--framer-color-bg-secondary);
    border: 1px solid var(--framer-color-border);
    border-radius: 0.375rem;
    padding: 0.375rem 0.875rem;
    font-size: 0.9375rem;
    color: var(--framer-color-text-secondary);
  }

  /* Experience */
  .about-experience {
    padding: 3rem 0 6rem;
    border-top: 1px solid var(--framer-color-border);
  }

  .experience-entry {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--framer-color-border);
  }

  .experience-entry:last-child {
    border-bottom: none;
  }

  .experience-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .experience-company {
    font-weight: 600;
    font-size: 1rem;
    color: var(--framer-color-text-primary);
  }

  .experience-period {
    font-size: 0.875rem;
    color: var(--framer-color-text-tertiary);
  }

  .experience-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--framer-color-text-secondary);
    margin: 0;
  }
</style>
