---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — Page Not Found | Colton Carroll">
  <main
    style="
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
      text-align: center;
      padding: 2rem;
    "
  >
    <h1 style="font-size: 4rem; color: var(--framer-color-text-primary); margin: 0;">404</h1>
    <p style="color: var(--framer-color-text-secondary); margin-top: 1rem;">This page does not exist.</p>
    <a href="/" style="color: var(--framer-color-accent); margin-top: 1.5rem;">Go home</a>
  </main>
</Layout>
