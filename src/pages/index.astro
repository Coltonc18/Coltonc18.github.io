---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { identity, projects, experience, education, skills } from '../data/site';

// Any image referenced in site.ts just needs to exist in src/assets/.
const assets = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
const img = (name?: string) => (name ? assets[`../assets/${name}`]?.default : undefined);

const portrait = img(identity.portrait);
const [firstName, ...restName] = identity.name.split(' ');
---

<Layout>
  <main>
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <h1>
            {firstName}<br /><span class="outline">{restName.join(' ')}</span>
          </h1>
          <p class="tagline">{identity.tagline}</p>
          <p class="blurb">{identity.blurb}</p>
          <div class="links">
            <a href={`mailto:${identity.email}`}>email</a>
            <a href={identity.github} target="_blank" rel="noopener">github</a>
            <a href={identity.linkedin} target="_blank" rel="noopener">linkedin</a>
            <a href={identity.resume} target="_blank">resume ↓</a>
          </div>
        </div>
        <figure class="portrait">
          <div class="frame">
            {
              portrait ? (
                <Image src={portrait} alt={identity.name} widths={[400, 800]} sizes="(max-width: 700px) 60vw, 300px" />
              ) : (
                <div class="portrait-placeholder mono">
                  <span>+</span>
                  <p>
                    portrait
                    <br />
                    4:5 · ≥1000px
                    <br />
                    src/assets/{identity.portrait}
                  </p>
                </div>
              )
            }
          </div>
          <figcaption class="mono">fig. 01 — {identity.location.toLowerCase()}</figcaption>
        </figure>
      </div>
    </section>

    <section id="projects">
      <p class="section-label reveal"><b>01</b> — Projects</p>
      {
        projects.map((p) => {
          const shot = img(p.image);
          return (
            <article class="entry reveal">
              <div class="entry-head">
                <h3>{p.link ? <a href={p.link} target="_blank" rel="noopener">{p.name}</a> : p.name}</h3>
                <span class="period">{p.period}</span>
              </div>
              <ul class="tags">
                {p.stack.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
              {shot && (
                <figure class="entry-figure">
                  <Image src={shot} alt={p.name} widths={[700, 1400]} sizes="(max-width: 44rem) 100vw, 40rem" />
                </figure>
              )}
              <p class="desc">{p.description}</p>
            </article>
          );
        })
      }
    </section>

    <section id="experience">
      <p class="section-label reveal"><b>02</b> — Experience</p>
      {
        experience.map((e) => (
          <article class="entry reveal">
            <div class="entry-head">
              <h3>{e.role}</h3>
              <span class="period">{e.period}</span>
            </div>
            <p class="org">{e.org}</p>
            <p class="desc">{e.description}</p>
          </article>
        ))
      }
    </section>

    <section id="education">
      <p class="section-label reveal"><b>03</b> — Education & Skills</p>
      <article class="entry reveal">
        <div class="entry-head">
          <h3>{education.school}</h3>
          <span class="period">{education.period}</span>
        </div>
        <p class="edu-meta">{education.degree} · GPA {education.gpa}</p>
        <p class="desc">Coursework: {education.coursework.join(', ')}</p>
      </article>
      <dl class="reveal">
        {
          Object.entries(skills).map(([group, items]) => (
            <div class="skills-row">
              <dt>{group}</dt>
              <dd>{items.join(', ')}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </main>
</Layout>
