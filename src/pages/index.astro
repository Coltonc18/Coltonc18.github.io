---
import Layout from '../layouts/Layout.astro';
import FramerSocialIcon from '../components/FramerSocialIcon.tsx';
---
<Layout title="Colton Carroll | Software Engineer">
  <main class="home-page">
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-name">Colton Carroll</h1>
        <p class="hero-tagline">Software Engineer</p>
        <p class="hero-description">
          Building fast, reliable software with a focus on clean code and great user experiences.
        </p>
        <div class="hero-actions">
          <a href="/work" class="cta-primary">View Work</a>
          <a href="/about" class="cta-secondary">About Me</a>
        </div>
        <div class="hero-social">
          <FramerSocialIcon
            link="https://github.com/Coltonc18"
            icon="github"
            client:only="react"
          />
          <FramerSocialIcon
            link="https://www.linkedin.com/in/colton-carroll/"
            icon="linkedin"
            client:only="react"
          />
        </div>
        <!-- Accessible fallback social links always present in DOM -->
        <div class="hero-social-fallback" aria-label="Social media links">
          <a href="https://github.com/Coltonc18" target="_blank" rel="noopener noreferrer" class="social-link">GitHub</a>
          <a href="https://www.linkedin.com/in/colton-carroll/" target="_blank" rel="noopener noreferrer" class="social-link">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-page {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }

  .hero {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #0d0d0d);
    margin: 0;
    line-height: 1.1;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 400;
    color: var(--token-e1f0f6fc-3f48-41e1-b11f-79a5bba9c5c2, #555);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .hero-description {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--token-e1f0f6fc-3f48-41e1-b11f-79a5bba9c5c2, #666);
    max-width: 480px;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .cta-primary {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #0d0d0d);
    color: #fff;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cta-primary:hover {
    opacity: 0.82;
  }

  .cta-secondary {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: transparent;
    color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #0d0d0d);
    border: 1.5px solid var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #0d0d0d);
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cta-secondary:hover {
    opacity: 0.65;
  }

  .hero-social {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.25rem;
    min-height: 36px;
  }

  /* Fallback links hidden visually but present for SEO and accessibility */
  .hero-social-fallback {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-color-scheme: dark) {
    .hero-name {
      color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
    }
    .hero-tagline,
    .hero-description {
      color: var(--token-e1f0f6fc-3f48-41e1-b11f-79a5bba9c5c2, #aaa);
    }
    .cta-primary {
      background: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
      color: #0d0d0d;
    }
    .cta-secondary {
      color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
      border-color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
    }
  }

  html.dark .hero-name {
    color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
  }
  html.dark .hero-tagline,
  html.dark .hero-description {
    color: var(--token-e1f0f6fc-3f48-41e1-b11f-79a5bba9c5c2, #aaa);
  }
  html.dark .cta-primary {
    background: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
    color: #0d0d0d;
  }
  html.dark .cta-secondary {
    color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
    border-color: var(--token-04d35c7a-9ed7-41b8-820c-4f9d7d04c87c, #f5f5f5);
  }
</style>
